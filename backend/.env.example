# --- Required ---
# MongoDB Atlas connection string (Database → Connect → Drivers → Python)
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGO_URL=mongodb+srv://<USER>:<PASSWORD>@<CLUSTER>.mongodb.net/?retryWrites=true&w=majority

# Mongo logical database name
DB_NAME=psuman_associates

# Comma-separated allowed origins (your deployed frontend URL — Vercel gives you one)
# Example: CORS_ORIGINS=https://psuman-associates.vercel.app,https://psumanassociates.com
CORS_ORIGINS=https://your-frontend.vercel.app

# Optional — Railway / Render set this automatically. Local dev defaults to 8001.
# PORT=8001
