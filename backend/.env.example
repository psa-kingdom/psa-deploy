# --- Required ---
# MongoDB Atlas connection string (Database → Connect → Drivers → Python)
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGO_URL=mongodb+srv://<USER>:<PASSWORD>@<CLUSTER>.mongodb.net/?retryWrites=true&w=majority

# Mongo logical database name
DB_NAME=psuman_associates

# ---------------------------------------------------------------------------
# CORS_ORIGINS — comma-separated list of allowed frontend origins.
# Include ALL Vercel domains for your project:
#   1. Production alias  →  https://psa-deploy.vercel.app
#   2. Custom domain     →  https://psumanassociates.com  (if configured)
#   3. Preview deploys   →  https://psa-deploy-git-main-yourteam.vercel.app
#
# NO trailing slashes. Whitespace around commas is stripped automatically.
#
# Example (set this as a Railway env var — do NOT commit real values):
# CORS_ORIGINS=https://psa-deploy.vercel.app,https://psumanassociates.com
# ---------------------------------------------------------------------------
CORS_ORIGINS=https://your-project.vercel.app

# Optional — Railway / Render set this automatically. Local dev defaults to 8001.
# PORT=8001
